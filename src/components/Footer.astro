---
import { Icon } from 'astro-icon/components';
import { Image } from "astro:assets"
import ContentWidth from "./ContentWidth.astro";

import logo from "../assets/logo-servitec.png";
---

<footer class="w-full bg-black pt-16 pb-32 border-t border-white/5 text-white">
  <ContentWidth>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <div class="flex flex-col items-center md:items-start gap-4">
        <Image
            src={logo}
            alt="Logo de Servitec"
            width="100"
            height="80"
            class="w-auto"
        />
        <p class="text-xs text-white/40 font-bold tracking-widest leading-relaxed text-center md:text-left max-w-xs">
          Líderes en tecnología digital y entretenimiento para el hogar en todo el Perú.
        </p>
        <div class="flex gap-4 mt-2">
          <a href="#" class="text-white/20 hover:text-[#f9e400] transition-colors"><Icon name="mdi:facebook" class="w-6 h-6" /></a>
          <a href="#" class="text-white/20 hover:text-[#f9e400] transition-colors"><Icon name="mdi:instagram" class="w-6 h-6" /></a>
          <a href="#" class="text-white/20 hover:text-[#f9e400] transition-colors"><Icon name="mdi:whatsapp" class="w-6 h-6" /></a>
        </div>
      </div>

      <div class="flex flex-col items-center md:items-start gap-4">
        <h4 class="text-sm font-black uppercase tracking-[0.2em] text-[#f9e400]">Pagos Seguros</h4>
        <p class="text-[10px] text-white/30 uppercase font-bold mb-2">Aceptamos todos los medios</p>

        <div class="grid grid-cols-3 gap-3">
          <div class="w-12 h-8 bg-white/5 border border-white/10 rounded-md flex items-center justify-center opacity-50">
            <Icon name="mdi:qrcode-scan" class="w-5 h-5" />
          </div>
          <div class="w-12 h-8 bg-white/5 border border-white/10 rounded-md flex items-center justify-center opacity-50">
            <Icon name="mdi:credit-card-outline" class="w-5 h-5" />
          </div>
          <div class="w-12 h-8 bg-white/5 border border-white/10 rounded-md flex items-center justify-center opacity-50 text-[8px] font-black">
            VISA
          </div>
        </div>
      </div>

    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col items-center gap-4">
      <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-white/20 text-center">
        © {new Date().getFullYear()} Servitec Publicidad Digital | Hecho en Perú 🇵🇪
      </p>
    </div>
  </ContentWidth>
</footer>