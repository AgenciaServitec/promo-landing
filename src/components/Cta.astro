---
import { Icon } from 'astro-icon/components';
import ContentWidth from "./ContentWidth.astro";
---

<section class="w-full bg-black py-12 md:py-20 text-white border-t border-white/5 overflow-hidden">
    <ContentWidth>
        <div class="max-w-2xl mx-auto flex flex-col items-center md:items-start gap-8 px-4">

            <div class="bg-red-600 text-white text-[10px] md:text-[11px] font-black px-4 py-1.5 rounded-full uppercase tracking-[0.15em] shadow-lg shadow-red-600/20 self-center md:self-start">
                SÓLO HOY -60% OFF
            </div>

            <div class="space-y-2 text-center md:text-left w-full">
                <h2 class="text-3xl sm:text-4xl md:text-6xl font-black tracking-tighter uppercase leading-[0.9]">
                    Proyector Epson
                </h2>
                <h3 class="text-3xl sm:text-4xl md:text-6xl font-black tracking-tighter uppercase leading-[0.9] italic text-[#f9e400]">
                    Home Cinema
                </h3>
            </div>

            <div class="flex flex-wrap items-baseline justify-center md:justify-start gap-3 w-full">
                <span class="text-5xl sm:text-6xl font-black tracking-tighter italic">S/ 3,299.90</span>
                <span class="text-xl sm:text-2xl font-bold text-white/20 line-through decoration-red-600/50">S/ 5,499.00</span>
            </div>

            <div class="grid grid-cols-1 xs:grid-cols-2 gap-4 w-full py-6 border-y border-white/10">
                <div class="flex items-center gap-3 bg-white/5 p-3 rounded-xl border border-white/5">
                    <Icon name="mdi:video-4k-box" class="w-6 h-6 text-[#f9e400] shrink-0" />
                    <span class="text-[11px] font-bold text-white/80 uppercase leading-tight">Resolución 4K PRO-UHD</span>
                </div>
                <div class="flex items-center gap-3 bg-white/5 p-3 rounded-xl border border-white/5">
                    <Icon name="mdi:white-balance-sunny" class="w-6 h-6 text-[#f9e400] shrink-0" />
                    <span class="text-[11px] font-bold text-white/80 uppercase leading-tight">3000 lúmenes de brillo</span>
                </div>
                <div class="flex items-center gap-3 bg-white/5 p-3 rounded-xl border border-white/5">
                    <Icon name="mdi:contrast-box" class="w-6 h-6 text-[#f9e400] shrink-0" />
                    <span class="text-[11px] font-bold text-white/80 uppercase leading-tight">Contraste 100,000:1</span>
                </div>
                <div class="flex items-center gap-3 bg-white/5 p-3 rounded-xl border border-white/5">
                    <Icon name="mdi:controller" class="w-6 h-6 text-[#f9e400] shrink-0" />
                    <span class="text-[11px] font-bold text-white/80 uppercase leading-tight">HDMI 2.0 & Gaming</span>
                </div>
            </div>

            <p class="text-base sm:text-lg text-white/50 leading-relaxed font-medium italic text-center md:text-left">
                Transforma cualquier habitación en una sala de cine. Calidad de imagen profesional con la tecnología 3LCD para colores vibrantes.
            </p>

            <div class="w-full space-y-4">
                <div class="flex items-center justify-center md:justify-start gap-2">
                    <div class="w-2 h-2 bg-red-600 rounded-full animate-ping"></div>
                    <p class="text-[11px] font-black uppercase tracking-widest text-[#f9e400]">La oferta termina en:</p>
                </div>

                <div class="grid grid-cols-4 gap-2 sm:gap-4 max-w-sm mx-auto md:mx-0">
                    <div class="flex flex-col items-center gap-1">
                        <div id="days-val" class="w-full aspect-square bg-white/5 border border-white/10 rounded-xl flex items-center justify-center text-2xl sm:text-3xl font-black text-[#f9e400]">00</div>
                        <span class="text-[9px] font-bold text-white/30 uppercase tracking-tighter">Días</span>
                    </div>
                    <div class="flex flex-col items-center gap-1">
                        <div id="hours-val" class="w-full aspect-square bg-white/5 border border-white/10 rounded-xl flex items-center justify-center text-2xl sm:text-3xl font-black text-[#f9e400]">02</div>
                        <span class="text-[9px] font-bold text-white/30 uppercase tracking-tighter">Horas</span>
                    </div>
                    <div class="flex flex-col items-center gap-1">
                        <div id="mins-val" class="w-full aspect-square bg-white/5 border border-white/10 rounded-xl flex items-center justify-center text-2xl sm:text-3xl font-black text-[#f9e400]">45</div>
                        <span class="text-[9px] font-bold text-white/30 uppercase tracking-tighter">Mins</span>
                    </div>
                    <div class="flex flex-col items-center gap-1">
                        <div id="segs-val" class="w-full aspect-square bg-[#f9e400]/10 border border-[#f9e400]/30 rounded-xl flex items-center justify-center text-2xl sm:text-3xl font-black text-[#f9e400]">12</div>
                        <span class="text-[9px] font-bold text-white/30 uppercase tracking-tighter">Segs</span>
                    </div>
                </div>
            </div>
        </div>
    </ContentWidth>
</section>

<script>
    const countdownDate = new Date("March 20, 2026 23:59:59").getTime();

    const updateCountdown = () => {
        const now = new Date().getTime();
        const distance = countdownDate - now;

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const dEl = document.getElementById("days-val");
        const hEl = document.getElementById("hours-val");
        const mEl = document.getElementById("mins-val");
        const sEl = document.getElementById("segs-val");

        if (dEl) dEl.innerText = days.toString().padStart(2, "0");
        if (hEl) hEl.innerText = hours.toString().padStart(2, "0");
        if (mEl) mEl.innerText = minutes.toString().padStart(2, "0");
        if (sEl) sEl.innerText = seconds.toString().padStart(2, "0");

        if (distance < 0) {
            clearInterval(timerInterval);
            if (dEl) dEl.innerText = "00";
            if (hEl) hEl.innerText = "00";
            if (mEl) mEl.innerText = "00";
            if (sEl) sEl.innerText = "00";
        }
    };

    const timerInterval = setInterval(updateCountdown, 1000);
    updateCountdown();
</script>